# LM Studio
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=qwen3.5-4b
LM_STUDIO_API_KEY=lm-studio
LM_STUDIO_TIMEOUT=60.0
LM_STUDIO_MAX_TOKENS=2048
