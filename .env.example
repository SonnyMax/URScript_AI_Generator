# Safety limits (change only if you know what you're doing)
MAX_JOINT_VELOCITY=1.05
MAX_JOINT_ACCEL=1.4
MAX_TCP_VELOCITY=0.5
MAX_TCP_ACCEL=1.2
MAX_WORKSPACE_RADIUS=1.5
