# A2 (bad): gripper closes BEFORE reaching the object and opens ABOVE the place
# pose -- polarity/ordering mistake the validator must warn about (W-GRIPPER).
def program():
  above_pick = p[0.30, -0.20, 0.25, 0.0, 3.1415, 0.0]
  pick = p[0.30, -0.20, 0.05, 0.0, 3.1415, 0.0]
  above_place = p[0.10, -0.35, 0.25, 0.0, 3.1415, 0.0]
  place = p[0.10, -0.35, 0.05, 0.0, 3.1415, 0.0]
  set_digital_out(0, True)
  movel(above_pick, a=0.5, v=0.2)
  movel(pick, a=0.5, v=0.1)
  sleep(0.5)
  movel(above_pick, a=0.5, v=0.2)
  movel(above_place, a=0.5, v=0.2)
  set_digital_out(0, False)
  movel(place, a=0.5, v=0.1)
  movel(above_place, a=0.5, v=0.2)
end
